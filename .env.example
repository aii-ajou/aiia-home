# Astro(SSR) → Directus(CMS) 연결 설정.
# 실제 값은 .env 에 넣고 커밋하지 않는다. (.env 는 .gitignore 처리됨)

# 서버 사이드에서 Directus API 를 호출할 기본 URL
#  - 로컬(npm/SQLite 또는 로컬 컨테이너): http://localhost:8055
#  - docker compose 내부 네트워크: http://directus:8055
DIRECTUS_URL=http://localhost:8055

# (선택) 읽기가 토큰으로 게이트된 경우에만 사용.
# 기본은 Public role 익명 읽기이므로 비워 둔다.
DIRECTUS_TOKEN=

# 브라우저에 노출되는 에셋 오리진(<img src>). 서버 사이드 DIRECTUS_URL 과
# 다를 수 있다(리버스 프록시/서브도메인 등). PUBLIC_ 접두사로 클라이언트에 노출.
PUBLIC_DIRECTUS_ASSET_URL=http://localhost:8055

# Directus Flow 웹훅이 /api/revalidate 로 캐시를 무효화할 때 공유하는 시크릿.
# 로컬/운영 각각 강한 임의값으로 교체할 것.
REVALIDATE_SECRET=change-me
