{
  "name": "aiia-cms",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "AIIA 홈페이지 Directus(CMS) — 로컬 npm+SQLite 런타임",
  "engines": {
    "node": "^18.20.8 || ^20.3.0 || >=22.0.0"
  },
  "scripts": {
    "bootstrap": "node --env-file=.env node_modules/directus/cli.js bootstrap",
    "start": "node --env-file=.env node_modules/directus/cli.js start",
    "build-schema": "node --env-file=.env schema/build-schema.mjs",
    "schema:snapshot": "node --env-file=.env node_modules/directus/cli.js schema snapshot --yes ./schema/snapshot.yaml",
    "schema:apply": "node --env-file=.env node_modules/directus/cli.js schema apply --yes ./schema/snapshot.yaml",
    "seed": "node --env-file=.env seed/seed.mjs",
    "flow": "node --env-file=.env seed/revalidate-flow.mjs"
  },
  "dependencies": {
    "directus": "^11.0.0"
  }
}
