# Directus 서버 환경변수 예시.
# 로컬(npm+SQLite): cms/.env 로 복사해 사용(커밋 안 함).
# 운영(Docker+Postgres): 배포 시크릿으로 주입(추후, docs/BACKLOG.md 참조).

# ---- 보안 키 (배포 시 반드시 강한 임의값으로) ----
KEY=replace-with-random-key
SECRET=replace-with-random-secret

# ---- DB : 로컬은 SQLite ----
DB_CLIENT=sqlite3
DB_FILENAME=./data.db
# 운영(Postgres) 예시:
# DB_CLIENT=pg
# DB_HOST=postgres
# DB_PORT=5432
# DB_DATABASE=aiia
# DB_USER=aiia
# DB_PASSWORD=replace

# ---- 최초 관리자 (bootstrap 시 생성, 로컬 더미) ----
# Directus 이메일 검증이 유효 TLD 를 요구하므로 admin@local 류는 거부된다.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin1234

# ---- 서버 ----
PUBLIC_URL=http://localhost:8055
PORT=8055

# ---- CORS : Astro dev(4321) / preview(4321) 허용 ----
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:4321

# ---- 업로드 저장 위치 ----
STORAGE_LOCATIONS=local
STORAGE_LOCAL_ROOT=./uploads

# ---- 게시 즉시 반영 Flow (콘텐츠 변경 → 웹앱 /api/revalidate 호출) ----
# 로컬은 웹앱이 localhost 라서 Directus SSRF 차단(IMPORT_IP_DENY_LIST)을 비워 loopback 허용.
# 운영에서는 실제 도메인/내부 서비스명을 쓰고 필요 시 좁게 설정할 것.
IMPORT_IP_DENY_LIST=
REVALIDATE_URL=http://localhost:4321/api/revalidate
REVALIDATE_SECRET=local-dev-secret

# ---- 아주대 SSO (추후) : 설정만으로 활성화, 앱/스키마 코드 변경 없음 ----
# AUTH_PROVIDERS=ajou
# AUTH_AJOU_DRIVER=openid
# AUTH_AJOU_CLIENT_ID=...
# AUTH_AJOU_CLIENT_SECRET=...
# AUTH_AJOU_ISSUER_URL=...
# AUTH_AJOU_IDENTIFIER_KEY=email
# AUTH_AJOU_ALLOW_PUBLIC_REGISTRATION=false
# AUTH_AJOU_DEFAULT_ROLE_ID=<Editor role UUID>
