# Decap OAuth 릴레이 설정 — 실제 값은 .env 에 넣고 커밋하지 않는다.

# GitHub OAuth App (조직 Settings → Developer settings → OAuth Apps 에서 생성)
#  - Authorization callback URL: https://<릴레이 도메인>/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# 관리 UI(/admin)가 뜨는 오리진 화이트리스트(콤마 구분). 비우면 전체 허용(개발용).
ALLOWED_ORIGINS=https://aiia.ajou.ac.kr

PORT=8788
