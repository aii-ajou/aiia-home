---
/**
 * About.astro — 연구원 소개 + 4대 지향점(pillars) 카드
 * 콘텐츠는 Directus 에서 온다.
 */
import type { AboutView } from "../lib/directus/queries";
import { nl2br } from "../lib/directus/html";
interface Props { about: AboutView }
const { about } = Astro.props;
---

<section id="about" class="section section--alt">
  <div class="aiia-container about">
    <div>
      <p class="eyebrow eyebrow--gold">{about.eyebrow}</p>
      <h2 class="section__title about__title" set:html={nl2br(about.title)}></h2>
      <p class="section__lede">{about.lede}</p>
    </div>
    <div class="pillars">
      {about.pillars.map((p) => (
        <div class="card pillar">
          <div class="pillar__icon" style={`background:${p.color}`}>{p.mono}</div>
          <div class="pillar__title">{p.title}</div>
          <p class="pillar__desc">{p.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .about {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: 56px;
    align-items: start;
  }
  .about__title {
    margin: 0 0 20px;
  }
  .pillars {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--aiia-space-4);
  }
  .pillar {
    padding: var(--aiia-space-6);
  }
  .pillar__icon {
    width: 40px;
    height: 40px;
    border-radius: var(--aiia-r-md);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--aiia-font-display);
    font-weight: 700;
    font-size: 15px;
    color: #fff;
    margin-bottom: var(--aiia-space-4);
  }
  .pillar__title {
    font-weight: 800;
    font-size: 16.5px;
    color: var(--aiia-ink);
    margin-bottom: var(--aiia-space-2);
  }
  .pillar__desc {
    margin: 0;
    font-size: 13.5px;
    line-height: 1.65;
    color: var(--aiia-ink-soft);
  }

  @media (max-width: 900px) {
    .about {
      grid-template-columns: 1fr;
    }
  }
</style>
