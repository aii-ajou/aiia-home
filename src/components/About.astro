---
/**
 * About.astro — 연구원 소개 + 4대 지향점(pillars) 카드
 */
const pillars = [
  { mono: "R", color: "var(--aiia-blue)", title: "연구", desc: "기초부터 응용까지 폭넓은 AI 연구를 수행합니다." },
  { mono: "P", color: "var(--aiia-gold)", title: "산학협력", desc: "기업·지자체와 공동연구·자문을 진행합니다." },
  { mono: "E", color: "var(--aiia-blue-bright)", title: "교육", desc: "차세대 AI 연구자를 육성합니다." },
  { mono: "O", color: "var(--aiia-success)", title: "개방", desc: "연구 성과를 사회와 공유합니다." },
];
---

<section id="about" class="section section--alt">
  <div class="aiia-container about">
    <div>
      <p class="eyebrow eyebrow--gold">About AIIA</p>
      <h2 class="section__title about__title">인공지능으로<br />더 나은 내일을 연구합니다</h2>
      <p class="section__lede">
        AIIA는 아주대학교의 인공지능 연구 역량을 하나로 모아, 학문적 성과와
        사회적 가치를 동시에 추구합니다. 기업·지자체와의 협력을 통해 연구가
        실제 문제 해결로 이어지도록 합니다.
      </p>
    </div>
    <div class="pillars">
      {pillars.map((p) => (
        <div class="card pillar">
          <div class="pillar__icon" style={`background:${p.color}`}>{p.mono}</div>
          <div class="pillar__title">{p.title}</div>
          <p class="pillar__desc">{p.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .about {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: 56px;
    align-items: start;
  }
  .about__title {
    margin: 0 0 20px;
  }
  .pillars {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--aiia-space-4);
  }
  .pillar {
    padding: var(--aiia-space-6);
  }
  .pillar__icon {
    width: 40px;
    height: 40px;
    border-radius: var(--aiia-r-md);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--aiia-font-display);
    font-weight: 700;
    font-size: 15px;
    color: #fff;
    margin-bottom: var(--aiia-space-4);
  }
  .pillar__title {
    font-weight: 800;
    font-size: 16.5px;
    color: var(--aiia-ink);
    margin-bottom: var(--aiia-space-2);
  }
  .pillar__desc {
    margin: 0;
    font-size: 13.5px;
    line-height: 1.65;
    color: var(--aiia-ink-soft);
  }

  @media (max-width: 900px) {
    .about {
      grid-template-columns: 1fr;
    }
  }
</style>
