---
/**
 * Contact.astro — 오시는 길 (연락처 + 지도 자리표시자)
 */
const contactInfo = [
  { label: "Address", value: "경기도 수원시 영통구 월드컵로 206\n아주대학교 인공지능연구원" },
  { label: "Tel", value: "031-219-0000" },
  { label: "Email", value: "aiia@ajou.ac.kr" },
];
---

<section id="contact" class="section">
  <div class="aiia-container">
    <p class="eyebrow eyebrow--gold">Location</p>
    <h2 class="section__title section__title--mb">오시는 길</h2>
    <div class="contact">
      <div class="contact__list">
        {contactInfo.map((c) => (
          <div>
            <div class="contact__label">{c.label}</div>
            <div class="contact__value">{c.value}</div>
          </div>
        ))}
      </div>
      <div class="contact__map">
        <span class="placeholder-chip">map embed / 캠퍼스 지도</span>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: var(--aiia-space-8);
    align-items: stretch;
  }
  .contact__list {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }
  .contact__label {
    font-family: var(--aiia-font-display);
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--aiia-ink-mute);
    margin-bottom: 6px;
  }
  .contact__value {
    font-size: 15.5px;
    line-height: 1.6;
    color: var(--aiia-ink);
    white-space: pre-line;
  }
  .contact__map {
    min-height: 280px;
    border-radius: var(--aiia-r-lg);
    overflow: hidden;
    border: 1px solid var(--aiia-line);
    background-color: var(--aiia-surface-2);
    background-image: repeating-linear-gradient(
      135deg,
      transparent,
      transparent 13px,
      rgba(0, 91, 172, 0.05) 13px,
      rgba(0, 91, 172, 0.05) 14px
    );
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (max-width: 900px) {
    .contact {
      grid-template-columns: 1fr;
    }
  }
</style>
