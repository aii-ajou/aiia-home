---
/**
 * Contact.astro — 오시는 길 (연락처 + 지도)
 * 콘텐츠는 Directus 에서 온다. 지도 이미지/임베드가 없으면 placeholder 유지.
 */
import type { ContactView } from "../lib/directus/queries";
interface Props { contact: ContactView }
const { contact } = Astro.props;
---

<section id="contact" class="section">
  <div class="aiia-container">
    <p class="eyebrow eyebrow--gold">{contact.eyebrow}</p>
    <h2 class="section__title section__title--mb">{contact.title}</h2>
    <div class="contact">
      <div class="contact__list">
        {contact.items.map((c) => (
          <div>
            <div class="contact__label">{c.label}</div>
            <div class="contact__value">{c.value}</div>
          </div>
        ))}
      </div>
      <div
        class="contact__map"
        style={contact.mapImage ? `background-image:url(${contact.mapImage});background-size:cover;background-position:center` : undefined}
      >
        {contact.mapEmbed
          ? <Fragment set:html={contact.mapEmbed} />
          : (contact.mapImage ? null : <span class="placeholder-chip">map embed / 캠퍼스 지도</span>)}
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: var(--aiia-space-8);
    align-items: stretch;
  }
  .contact__list {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }
  .contact__label {
    font-family: var(--aiia-font-display);
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--aiia-ink-mute);
    margin-bottom: 6px;
  }
  .contact__value {
    font-size: 15.5px;
    line-height: 1.6;
    color: var(--aiia-ink);
    white-space: pre-line;
  }
  .contact__map {
    min-height: 280px;
    border-radius: var(--aiia-r-lg);
    overflow: hidden;
    border: 1px solid var(--aiia-line);
    background-color: var(--aiia-surface-2);
    background-image: repeating-linear-gradient(
      135deg,
      transparent,
      transparent 13px,
      rgba(0, 91, 172, 0.05) 13px,
      rgba(0, 91, 172, 0.05) 14px
    );
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (max-width: 900px) {
    .contact {
      grid-template-columns: 1fr;
    }
  }
</style>
