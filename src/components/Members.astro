---
/**
 * Members.astro — 주요 구성원 카드 그리드
 * 콘텐츠는 Directus 에서 온다. 사진(photo)이 없으면 accent 색 + placeholder 유지.
 */
import type { MemberView } from "../lib/directus/queries";
interface Props { members: MemberView[] }
const { members } = Astro.props;
---

<section id="members" class="section section--alt">
  <div class="aiia-container">
    <div class="section__head">
      <div>
        <p class="eyebrow eyebrow--gold">Members</p>
        <h2 class="section__title">구성원</h2>
      </div>
      <a href="#members" class="section__link">전체 구성원 보기 →</a>
    </div>
    <div class="grid grid--members">
      {members.map((m) => (
        <div class="card member">
          <div
            class="member__photo"
            style={m.photo ? `background-image:url(${m.photo});background-size:cover;background-position:center` : `background-color:${m.color}`}
          >
            {m.photo ? null : <span class="placeholder-chip placeholder-chip--dark">member photo</span>}
          </div>
          <div class="member__body">
            <div class="member__name">{m.name}</div>
            <div class="member__role">{m.role}</div>
            <div class="member__area">{m.area}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .grid--members {
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 18px;
  }
  .member {
    overflow: hidden;
  }
  .member__photo {
    height: 150px;
    background-image: repeating-linear-gradient(
      135deg,
      transparent,
      transparent 10px,
      rgba(255, 255, 255, 0.08) 10px,
      rgba(255, 255, 255, 0.08) 11px
    );
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 14px;
  }
  .member__body {
    padding: 16px 18px 20px;
  }
  .member__name {
    font-weight: 800;
    font-size: 16px;
    color: var(--aiia-ink);
  }
  .member__role {
    font-size: 12.5px;
    color: var(--aiia-primary);
    font-weight: 700;
    margin-top: 3px;
  }
  .member__area {
    font-family: var(--aiia-font-display);
    font-size: 11.5px;
    color: var(--aiia-ink-mute);
    margin-top: 6px;
  }
</style>
