---
/**
 * Stats.astro — 핵심 지표 스트립 (딥블루 배경)
 * 콘텐츠는 Directus 에서 온다.
 */
import type { StatView } from "../lib/content/queries";
interface Props { stats: StatView[] }
const { stats } = Astro.props;
---

<section class="stats">
  <div class="aiia-container stats__grid">
    {stats.map((s) => (
      <div class="stat">
        <div class="stat__value">{s.value}</div>
        <div class="stat__key">{s.label}</div>
      </div>
    ))}
  </div>
</section>

<style>
  .stats {
    background: var(--aiia-blue-deep);
    padding-block: 56px;
  }
  .stats__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: var(--aiia-space-6);
  }
  .stat {
    text-align: center;
    padding: var(--aiia-space-2) 0;
  }
  .stat__value {
    font-family: var(--aiia-font-display);
    font-weight: 700;
    font-size: 46px;
    line-height: 1;
    color: #fff;
  }
  .stat__key {
    margin-top: 10px;
    font-size: 14px;
    color: var(--aiia-sky);
  }
</style>
