---
/**
 * Base.astro — AIIA 홈페이지 공통 레이아웃
 * 아주대학교 인공지능연구원 (AI Institute of Ajou University)
 *
 * 역할:
 *  - 폰트 로딩 (Nanum Gothic · Space Grotesk)
 *  - 디자인 토큰(global.css → aiia-tokens.css) 로드
 *  - 라이트/다크 테마 초기화 (FOUC 방지) + localStorage 유지
 *  - 기본 SEO 메타 / OG 태그
 *
 * 사용:
 *  ---
 *  import Base from "../layouts/Base.astro";
 *  ---
 *  <Base title="아주대학교 인공지능연구원" description="...">
 *    <Header /> <Hero /> ...
 *  </Base>
 */
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  lang?: "ko" | "en";
  ogImage?: string;
}

const {
  title = "아주대학교 인공지능연구원 · AIIA",
  description = "아주대학교 인공지능연구원(AIIA) — 기초 연구부터 산업 응용까지, 인공지능의 최전선을 넓혀갑니다.",
  lang = "ko",
  ogImage = "/brand/og-cover.png",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://aiia.ajou.ac.kr");
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicon (아주대 UI 애플리케이션 파비콘으로 교체) -->
    <link rel="icon" type="image/png" href="/brand/favicon.png" />
    <link rel="apple-touch-icon" href="/brand/apple-touch-icon.png" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={lang === "ko" ? "ko_KR" : "en_US"} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Nanum+Gothic:wght@400;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- 테마 초기화: 첫 페인트 전에 실행되어 다크모드 깜빡임(FOUC) 방지 -->
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem("aiia-theme");
          var theme =
            saved ||
            (window.matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light");
          document.documentElement.dataset.theme = theme;
        } catch (e) {
          document.documentElement.dataset.theme = "light";
        }
      })();
    </script>
  </head>

  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* aiia-tokens.css 변수에 연결되는 최소 전역 리셋만. 나머지 스타일은 각 컴포넌트에서 토큰 변수로 작성. */
  * {
    box-sizing: border-box;
  }
  html {
    scroll-behavior: smooth;
  }
  body {
    margin: 0;
    background: var(--aiia-bg);
    color: var(--aiia-ink);
    font-family: var(--aiia-font-sans);
    -webkit-font-smoothing: antialiased;
  }
  ::selection {
    background: rgba(0, 91, 172, 0.18);
  }
  a {
    color: inherit;
  }
</style>
